{
  "name": "growup",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve -o --project=shell",
    "build": "ng build --project=shell",
    "watch": "ng build --watch --configuration development",
    "teacher": "npm run dev --prefix projects/teacher",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "start:proxy": "ng serve --proxy-config proxy.conf.json"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/service-worker": "^21.1.0",
    "@primeng/themes": "^21.0.4",
    "@softarc/native-federation-node": "^3.3.4",
    "chart.js": "^4.5.1",
    "es-module-shims": "^1.5.12",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.4",
    "primereact": "^10.9.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.12.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.1.0",
    "@angular-devkit/build-angular": "^21.1.0",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular/build": "^21.1.0",
    "@angular/cli": "^21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "angular-eslint": "^21.3.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^10.3.0",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.0.8"
  }
}
